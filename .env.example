# ─── Client-side (exposed to browser via VITE_ prefix) ───
# Optional browser-side Groq voice fallback.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=
VITE_SENTRY_DSN=
VITE_GROQ_API_KEY=

# ─── Server-side (api/ functions only) ───
GEMINI_API_KEY=
# Server-only Groq key for post-call transcript analysis / sheet enrichment.
GROQ_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ZOHO_EMAIL=
ZOHO_APP_PASSWORD=

# ─── Optional ───
# Legacy fallback only. Gemini Live should authenticate via
# /api/voice/token server-issued auth tokens.
VITE_GEMINI_API_KEY=

VOICE_AUDIO_MAX_BYTES=26214400
SUPABASE_STORAGE_BUCKET_VOICE_AUDIO=voice-session-audio
TRACKING_HASH_SALT=reynubixvoice
SHEET_ANALYSIS_PROVIDER=auto
GEMINI_SHEET_ANALYSIS_MODEL=gemini-2.5-flash
GROQ_SHEET_ANALYSIS_MODEL=qwen/qwen3-32b
SHEET_ANALYSIS_TRANSCRIPT_MAX_CHARS=30000

# Google Sheets auth
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=reyna web

# Preferred for Docker/server deployments
# Share the target sheet with the service-account email.
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_ID=

# Legacy OAuth refresh-token fallback
# Google may expire refresh tokens for testing-mode OAuth apps.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ─── Integrations ───
N8N_WEBHOOK_URL=https://n8n.srv1093654.hstgr.cloud/webhook/contact-lead
N8N_POST_CALL_WEBHOOK_URL=
RETELL_API_KEY=
N8N_WEBHOOK_SECRET=
